{
  "expo": {
    "name": "MoiHub",
    "slug": "moihubapp",
    "version": "1.0.0",
    "sdkVersion": "53.0.0",
    "orientation": "portrait",
    "icon": "./assets/appicon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#005f4b",
      "resizeMode": "contain",
      "image": "./assets/moihublogo.png"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "bundleIdentifier": "com.kylexvin.moihub",
      "supportsTablet": true,
      "infoPlist": {
        "NSUserTrackingUsageDescription": "This identifier will be used for notifications."
      }
    },
    "android": {
      "package": "com.kylexvin.moihub",
      "versionCode": 1,
      "permissions": [
        "NOTIFICATIONS",
        "CAMERA",
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "VIBRATE",
        "ACCESS_NETWORK_STATE",
        "WAKE_LOCK",
        "FOREGROUND_SERVICE",
        "com.google.android.c2dm.permission.RECEIVE"
      ],
      "googleServicesFile": "./android/app/google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/appicon.png",
        "backgroundColor": "#f2f5f4ff"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            { "scheme": "https", "host": "wa.me" },
            { "scheme": "https", "host": "api.whatsapp.com" },
            { "scheme": "whatsapp" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/moihublogo.png"
    },
    "plugins": [
      "expo-audio",
      "expo-web-browser",
      "expo-notifications",
      "@react-native-firebase/app",
      "@react-native-firebase/messaging",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 21
          }
        }
      ]
    ],
    "scheme": "moihubapp",
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "extra": {
      "eas": {
        "projectId": "f91d711b-81b0-48e2-9926-0b09b22e357f"
      }
    }
  }
}
