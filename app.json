{
  "expo": {
    "name": "MoiHub",
    "slug": "moihubapp",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/appicon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#005f4b",
      "resizeMode": "contain",
      "image": "./assets/moihublogo.png"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.kylexvin.moihub",
      "supportsTablet": true,
      "infoPlist": {
        "NSUserTrackingUsageDescription": "This identifier will be used for notifications."
      }
    },
    "android": {
      "package": "com.kylexvin.moihub",
      "versionCode": 3,
      "permissions": [
        "NOTIFICATIONS",
        "CAMERA",
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "VIBRATE",
        "ACCESS_NETWORK_STATE",
        "WAKE_LOCK",
        "FOREGROUND_SERVICE",
        "com.google.android.c2dm.permission.RECEIVE",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "googleServicesFile": "./android/app/google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/appicon.png",
        "backgroundColor": "#f2f5f4ff"
      }
    },
    "web": {
      "favicon": "./assets/moihublogo.png"
    },
    "plugins": [
      "expo-audio",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/ic_stat_notification.png",
          "color": "#005f4b"
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/messaging",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 21
          }
        }
      ]
    ],
    "scheme": "moihubapp",
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "extra": {
      "eas": {
        "projectId": "2fe67dfd-7c68-4c43-a61f-5fb4ce28cc1d"
      }
    },
    "owner": "kylexvinny"
  }
}