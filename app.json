{
  "expo": {
    "name": "MoiHub",
    "slug": "moihubapp",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/appicon.png",
    "userInterfaceStyle": "dark",
    "scheme": "moihubapp",
    "splash": {
      "backgroundColor": "#093028",
      "resizeMode": "contain",
      "image": "./assets/moihublogo.png"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.kylexvin.moihub",
      "supportsTablet": true,
      "infoPlist": {
        "NSUserTrackingUsageDescription": "This identifier will be used for notifications and personalized experience."
      }
    },
    "android": {
      "package": "com.kylexvin.moihub",
      "versionCode": 3,
      "permissions": [
        "NOTIFICATIONS",
        "CAMERA",
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "VIBRATE",
        "ACCESS_NETWORK_STATE",
        "WAKE_LOCK",
        "FOREGROUND_SERVICE"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "com.kylexvin.moihub",
              "host": "oauth2redirect"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        },
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "com.kylexvin.moihub",
              "host": "github-auth"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "googleServicesFile": "./android/app/google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/appicon.png",
        "backgroundColor": "#093028"
      }
    },
    "web": {
      "favicon": "./assets/moihublogo.png"
    },
    "plugins": [
      "expo-audio",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/ic_stat_notification.png",
          "color": "#00C896"
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/messaging",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 23
          }
        }
      ],
      "expo-sqlite"
    ],
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "extra": {
      "backendUrl": "https://moihub.onrender.com",
      "eas": {
        "projectId": "2fe67dfd-7c68-4c43-a61f-5fb4ce28cc1d"
      }
    },
    "owner": "kylexvinny"
  }
} 